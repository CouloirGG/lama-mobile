{
  "expo": {
    "name": "LAMA Mobile",
    "slug": "lama-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "lama-mobile",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0b08"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.couloirgg.lama.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0b08"
      },
      "package": "com.couloirgg.lama.mobile"
    },
    "plugins": [
      "expo-font",
      "expo-asset",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "LAMA needs camera access to scan QR codes for desktop pairing."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d22fcb5f-dfbd-444a-8857-6cb23ddae06e"
      }
    }
  }
}
